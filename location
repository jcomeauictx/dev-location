#!/sbin/openrc-run
# https://medium.com/@der.loste.kitkat/get-started-with-ish-b29add1f72a3
description="Ensure iSH continues to run in the background"
supervisor=supervise-daemon
# 5 minute rest between crashes
respawn_delay=300
command="/bin/bash"
command_args="/root/.local/bin/location.sh"
command_background=true
pidfile="/var/run/location.pid"
